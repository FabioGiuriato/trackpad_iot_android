        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarColor">@color/trackpad_bg_bottom</item>
        <item name="android:statusBarColor">@color/trackpad_bg_top</item>
        <item name="android:windowBackground">@color/trackpad_bg_top</item>
        <item name="android:colorAccent">@color/trackpad_accent</item>
        <item name="colorPrimary">@color/trackpad_accent</item>
        <item name="colorSecondary">@color/trackpad_cyan</item>
